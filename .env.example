# ═══════════════════════════════════════════════════════════════════
# G4Lite — Environment Configuration Template
#
# Copy to .env and edit before running:
#   cp .env.example .env
#
# Variables marked [REQUIRED IN PRODUCTION] MUST be changed before deploying.
# ═══════════════════════════════════════════════════════════════════


# ─── Database ──────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=g4light
POSTGRES_USER=g4admin
POSTGRES_PASSWORD=changeme                          # [REQUIRED IN PRODUCTION]

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false


# ─── Security / JWT ────────────────────────────────────────────────
# Generate a production key:
#   python -c "from app.config import Settings; print(Settings.generate_secret_key())"
SECRET_KEY=replace-with-64-char-random-string-generated-for-production-use   # [REQUIRED IN PRODUCTION]
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7


# ─── Password Policy ───────────────────────────────────────────────
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_AGE_DAYS=90


# ─── Account Lockout ───────────────────────────────────────────────
MAX_FAILED_LOGIN_ATTEMPTS=8
LOCKOUT_ESCALATION_MINUTES=5,15,60


# ─── Activity Tracking ─────────────────────────────────────────────
LAST_ACTIVE_THROTTLE_SECONDS=60


# ─── Application ───────────────────────────────────────────────────
ENVIRONMENT=development                             # development | staging | production | testing
APP_NAME=G4Lite
APP_VERSION=2.0.0
LOG_LEVEL=INFO
LOG_FORMAT=text                                     # text (dev) | json (prod)

MAX_ADMIN_ACCOUNTS=2
MAX_TOTAL_ACCOUNTS=12
SEED_ON_STARTUP=false


# ─── CORS ──────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=600


# ─── Ollama (optional AI assistant) ────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral
OLLAMA_CONNECT_TIMEOUT=5.0
OLLAMA_READ_TIMEOUT=120.0
OLLAMA_MAX_RETRIES=2
OLLAMA_CIRCUIT_BREAKER_THRESHOLD=5
OLLAMA_CIRCUIT_BREAKER_COOLDOWN=60


# ─── Physical Access Control (optional) ───────────────────────────
LOCK_ENABLED=false
LOCK_TYPE=mock                                      # mock | nuki | esp32
LOCK_API_URL=
LOCK_API_KEY=
LOCK_TIMEOUT_SECONDS=30
ACCESS_PIN_VALIDITY_MINUTES=15
ACCESS_PIN_LENGTH=6


# ─── Notifications (background scan intervals) ────────────────────
OVERDUE_CHECK_INTERVAL_MINUTES=60
OVERDUE_ESCALATION_HOURS=48
LOW_STOCK_CHECK_INTERVAL_MINUTES=360
NOTIFICATION_EXPIRY_DAYS=90


# ─── Docker Compose ────────────────────────────────────────────────
LISTEN_PORT=80
# LISTEN_PORT_TLS=443